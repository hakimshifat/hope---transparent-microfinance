NODE_ENV=production
PORT=5000

# PostgreSQL — change for your environment
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/hope_microfinance"

# JWT — CHANGE THIS to a long random string in production
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# CORS — set to your frontend origin in production
CLIENT_URL=http://localhost:5173

# Default admin (created on first boot if no admin exists)
DEFAULT_ADMIN_NAME=System Admin
DEFAULT_ADMIN_PHONE=01700000000
DEFAULT_ADMIN_EMAIL=admin@hope.local
DEFAULT_ADMIN_PASSWORD=Admin123!
